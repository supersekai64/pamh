{
  "name": "pamh-core",
  "version": "0.1.4",
  "description": "PAMH Core - Memory storage, indexing and search",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supersekai64/pamh.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/supersekai64/pamh#readme",
  "bugs": {
    "url": "https://github.com/supersekai64/pamh/issues"
  },
  "keywords": [
    "ai",
    "memory",
    "llm",
    "mcp",
    "sqlite"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc",
    "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.10.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.2.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@xenova/transformers": "^2.17.2"
  }
}
