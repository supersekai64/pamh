{
  "name": "@helloworlkd/pam-ui",
  "version": "1.0.6",
  "description": "PAM UI - Local web interface for PAM",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supersekai64/pam.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/supersekai64/pam#readme",
  "bugs": {
    "url": "https://github.com/supersekai64/pam/issues"
  },
  "keywords": [
    "ai",
    "memory",
    "llm",
    "ui"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && vite build && tsc -p tsconfig.json",
    "dev": "vite --host 127.0.0.1"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "vite": "^7.2.7",
    "@helloworlkd/pam-core": "workspace:^"
  }
}
