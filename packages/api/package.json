{
  "name": "pamh-api",
  "version": "0.1.10",
  "description": "PAMH API - Local HTTP API for PAMH clients",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supersekai64/pamh.git",
    "directory": "packages/api"
  },
  "homepage": "https://github.com/supersekai64/pamh#readme",
  "bugs": {
    "url": "https://github.com/supersekai64/pamh/issues"
  },
  "keywords": [
    "ai",
    "memory",
    "llm",
    "api"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc",
    "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pamh-core": "^0.1.5",
    "pamh-ui": "^0.1.7"
  }
}
