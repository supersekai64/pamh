{
  "name": "@helloworlkd/pam-cli",
  "version": "0.1.22",
  "description": "PAM CLI - Command line interface for PAM",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supersekai64/pam.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/supersekai64/pam#readme",
  "bugs": {
    "url": "https://github.com/supersekai64/pam/issues"
  },
  "keywords": [
    "ai",
    "memory",
    "llm",
    "mcp",
    "cli"
  ],
  "bin": {
    "pam": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc",
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "tsc --watch"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "zod": "^4.4.3",
    "@helloworlkd/pam-core": "workspace:^",
    "@helloworlkd/pam-protocol": "workspace:^",
    "@helloworlkd/pam-api": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.9.3"
  }
}
