{
  "name": "pam-monorepo",
  "version": "0.1.1",
  "private": true,
  "description": "Portable AI Memory",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "setup": "pnpm install && pnpm build && pnpm link:cli",
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "link:cli": "npm --prefix packages/cli link",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:check": "node scripts/check-packed-manifests.mjs",
    "release:check": "pnpm test && pnpm lint && pnpm build && pnpm pack:check && pnpm format:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
